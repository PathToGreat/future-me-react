# Example environment variables for reference
# Copy this file to .env and fill in your Firebase credentials

# For Expo, environment variables need to be prefixed with EXPO_PUBLIC_
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# Legacy variables (keeping for compatibility)
FIREBASE_API_KEY=your_api_key_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_APP_ID=your_app_id_here