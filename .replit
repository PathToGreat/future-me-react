modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Future Me React App"

[[workflows.workflow]]
name = "Future Me React App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd future-me-app && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
publicDir = "future-me-app/dist"
run = ["sh", "-c", "cd future-me-app && NODE_ENV=production node server/index.js"]
build = ["bash", "-c", "cd future-me-app && npm install && npm run build"]

[[ports]]
localPort = 3001
externalPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 9000

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 3002

[[ports]]
localPort = 5004
externalPort = 3003

[[ports]]
localPort = 5005
externalPort = 4200

[[ports]]
localPort = 5050
externalPort = 5000

[[ports]]
localPort = 5555
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8099

[[ports]]
localPort = 9005
externalPort = 8081

[[ports]]
localPort = 19006
externalPort = 6000

[[ports]]
localPort = 19007
externalPort = 6800

[agent]
expertMode = true
