modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Future Me React App"

[[workflows.workflow]]
name = "Future Me React App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd future-me-app && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
publicDir = "simple-test"
run = ["sh", "-c", "npx serve -s simple-test -l 5000"]
build = ["sh", "-c", "cd future-me-app && npm run build && cp -r dist/* ../simple-test/"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 3002

[[ports]]
localPort = 5004
externalPort = 3003

