modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Future Me React App"

[[workflows.workflow]]
name = "Future Me React App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd future-me-app && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd future-me-app && NODE_ENV=production node server/index.js"]
build = ["bash", "-c", "cd future-me-app && npm install && npm run build"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
