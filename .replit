modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Basic Test Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "React Test Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Simple HTML Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Future Me Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Clean React Native Test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "React Native Web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Pure HTML Test"

[[workflows.workflow]]
name = "Basic Test Server"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd test-app && python -m http.server 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "React Test Server"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd react-test && python -m http.server 5001"
waitForPort = 5001

[[workflows.workflow]]
name = "Simple HTML Server"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd simple-test && python -m http.server 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Future Me Server"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd simple-test && python -m http.server 5002"
waitForPort = 5002

[[workflows.workflow]]
name = "Expo Web"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx expo start --web --port=5001"
waitForPort = 5001

[[workflows.workflow]]
name = "Clean React Native Test"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd clean-react-native-test && npx expo start --web --port=5003"
waitForPort = 5003

[[workflows.workflow]]
name = "React Native Web"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx expo start --web --port=5004"
waitForPort = 5004

[[workflows.workflow]]
name = "Pure HTML Test"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd pure-html && python -m http.server 5000"
waitForPort = 5000

[deployment]
deploymentTarget = "static"
publicDir = "simple-test"
run = ["sh", "-c", "npx expo start --web --port=5000"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 3002

[[ports]]
localPort = 5004
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080
